# Path to your Madden 26 .ros roster file (optional - used for current player rating benchmarks)
ROSTER_FILE=

# Ollama host (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Ollama model to use
OLLAMA_MODEL=llama3:8b

# Number of prospects to generate (default: 250)
NUM_PROSPECTS=250

# Output directory
OUTPUT_DIR=./data/output
