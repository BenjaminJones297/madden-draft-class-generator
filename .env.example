# Path to your Madden 26 .ros roster file (optional - used for current player rating benchmarks)
ROSTER_FILE=

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Which LLM provider to use for rating generation.
# Options:
#   ollama           — Local Ollama server (default, no API key required)
#   ollama-langchain — Same Ollama server but routed through LangChain
#   openai           — OpenAI API via LangChain (requires OPENAI_API_KEY)
LLM_PROVIDER=ollama

# Ollama host (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Ollama model to use (for the ollama / ollama-langchain providers)
OLLAMA_MODEL=llama3:8b

# ── OpenAI (only needed when LLM_PROVIDER=openai) ────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Number of prospects to generate (default: 250)
NUM_PROSPECTS=250

# Output directory
OUTPUT_DIR=./data/output
