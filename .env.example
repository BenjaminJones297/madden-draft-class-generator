# ── Legacy CLI settings (run.py / roster_run.py) ─────────────────────────────

# Path to your Madden 26 .ros roster file (optional - used for current player rating benchmarks)
ROSTER_FILE=C:\Users\benja\repos\madden-draft-class-generator\data\ai_powered_26_class.ros

# Ollama host (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Ollama model to use
OLLAMA_MODEL=llama3:8b

# Number of prospects to generate (default: 250)
NUM_PROSPECTS=250

# Output directory
OUTPUT_DIR=./data/output

# ── Backend (FastAPI + Docker Compose) ───────────────────────────────────────

# PostgreSQL password (used by docker-compose.yml)
DB_PASS=changeme_strong_password

# Database connection URL (asyncpg for FastAPI)
DATABASE_URL=postgresql+asyncpg://madden:changeme_strong_password@localhost:5432/madden

# Redis connection URL
REDIS_URL=redis://localhost:6379

# Node.js sidecar URL (internal — do not expose publicly)
NODE_SIDECAR_URL=http://localhost:3001

# File storage backend: 'local' or 's3'
STORAGE_BACKEND=local

# Local file storage path (used when STORAGE_BACKEND=local)
STORAGE_LOCAL_PATH=./data/files

# ── Cloud LLM providers (optional — leave blank to use Ollama only) ───────────

# OpenAI API key (for GPT-4o / GPT-4o-mini)
OPENAI_API_KEY=

# Anthropic API key (for Claude Haiku / Claude Sonnet)
ANTHROPIC_API_KEY=

# ── AWS S3 (optional — only needed when STORAGE_BACKEND=s3) ──────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=madden-files
