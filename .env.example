# Path to your Madden 26 .ros roster file (optional - used for current player rating benchmarks)
ROSTER_FILE=

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Which LLM provider to use for rating generation.
# Options:
#   ollama           — Local Ollama server (default, no API key required)
#   ollama-langchain — Same Ollama server but routed through LangChain
#   openai           — OpenAI API via LangChain (requires OPENAI_API_KEY)
#   multi-chain      — 3-chain decomposition strategy via LangChain (best quality)
#                      Chain 1 (athleticism): combine measurables → physical ratings
#                      Chain 2 (skills):      position context → skill ratings   [parallel]
#                      Chain 3 (dev/overall): merged context → OVR + devTrait    [sequential]
LLM_PROVIDER=ollama

# Ollama host (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Ollama model to use (for the ollama / ollama-langchain providers)
OLLAMA_MODEL=llama3:8b

# ── OpenAI (only needed when LLM_PROVIDER=openai or multi-chain with OpenAI backend) ─
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── Multi-chain settings (only used when LLM_PROVIDER=multi-chain) ────────────
# Optional: use a smaller/faster model for the athleticism chain (Chain 1).
# Physical attribute mapping from combine measurables is nearly formulaic —
# a smaller model works well and reduces cost/latency.
# ATHLETICISM_MODEL=llama3:8b

# Number of prospects to generate (default: 250)
NUM_PROSPECTS=250

# Output directory
OUTPUT_DIR=./data/output
